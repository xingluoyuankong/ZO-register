{
  "manifest_version": 3,
  "name": "Turnstile Bypass",
  "version": "2.1",
  "description": "Cloudflare Turnstile screenX/screenY bypass",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "js": ["script.js"],
      "matches": ["<all_urls>"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ]
}
